# Backend Environment Variables Template

# 1. Server Configuration
PORT=5000

# 2. Security (JWT)
# Generate a secure string for your JSON Web Tokens
JWT_SECRET=your_super_secret_jwt_key

# 3. Frontend Integration
# Comma-separated list of allowed origins (CORS)
# Include localhost for dev, and your Vercel domains for prod
FRONTEND_URL=https://rent-a-fellow.vercel.app,https://prssn-frontend.vercel.app,https://www.prsnn.com,https://prsnn.com,http://localhost:3000

# 4. Database (MongoDB)
# Your MongoDB connection string
MONGO_DB_URI=mongodb+srv://username:password@cluster.mongodb.net/yourDatabase

# 5. Cloudinary (Image Uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# 6. Email Configuration (Resend)
# Used for OTPs and notifications
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@yourdomain.com

# 7. Stripe (Payments)
# Secret key (Starts with sk_test_ or sk_live_)
STRIPE_SECRET_KEY=your_stripe_secret_key
# Publishable key (Starts with pk_test_ or pk_live_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
